# ==================== BACKEND NEST.JS ====================
# NODE_ENV controla comportamiento de logs y stack traces en errores
# development: muestra stack traces completos | production: oculta detalles sensibles
NODE_ENV=development
NESTJS_PORT=3000

# CORS Configuration
CORS_ORIGINS=


# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m

# ==================== MONGODB ====================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=imox_mongo
MONGO_PORT=27017
DATABASE_URL_MONGO="mongodb://admin:admin123@localhost:27017/imox_mongo"

# ==================== MYSQL ====================
MYSQL_USER=imox_user
MYSQL_PASSWORD=imox_pass
MYSQL_DATABASE=imox_auth
MYSQL_ROOT_PASSWORD=admin123
MYSQL_PORT=3306
# Prisma connection string
MYSQL_URL="mysql://imox_user:imox_pass@localhost:3306/imox_auth"

# ==================== MQTT BROKER ====================
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ==================== REDIS (Sesiones y Caché) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

REDIS_URL=redis://:redis_password_change_in_production@localhost:6379
# En Docker: REDIS_URL=redis://:password@redis:6379

# ==================== GLITCHTIP ====================
GLITCHTIP_PORT=8000
# ==================== BREVO (Email) ====================
BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_SENDER=noreply@tu-dominio-verificado.com

# IMPORTANTE: Generar con: openssl rand -hex 50
# Debe tener mínimo 50 caracteres
GLITCHTIP_SECRET_KEY=change-this-to-a-random-secret-key-min-50-chars-use-openssl-rand

GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=noreply@imox.local
GLITCHTIP_EMAIL_URL=consolemail://

# DSN del proyecto
GLITCHTIP_DSN=
