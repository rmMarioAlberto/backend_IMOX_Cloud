# ==================== BACKEND NEST.JS ====================
NODE_ENV=development
NESTJS_PORT=3000

# CORS Configuration
CORS_ORIGINS=

# JWT Configuration
JWT_REFRESH_SECRET="your-super-secret-jwt-key-change-in-production_refresh"
JWT_ACCESS_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m

# ==================== INFLUXDB (Time Series) ====================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=clave_influxdb
INFLUXDB_ORG=imox_org
INFLUXDB_BUCKET=imox_bucket

# ==================== MARIADB (Relational) ====================
MYSQL_USER=imox_user
MYSQL_PASSWORD=imox_pass
MYSQL_DATABASE=imox_auth
MYSQL_ROOT_PASSWORD=admin123
MYSQL_PORT=3306
# Prisma connection string
MYSQL_URL="mysql://imox_user:imox_pass@localhost:3306/imox_auth"

# ==================== TELEMETRY & SPIKE DETECTION ====================
TELEMETRY_SPIKE_THRESHOLD=0.15
TELEMETRY_VOLTAGE_MAX=140
TELEMETRY_VOLTAGE_MIN=90
TELEMETRY_OFFLINE_TIMEOUT_MIN=10

# ==================== MQTT BROKER ====================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=imox_backend
MQTT_USER=backend_admin
MQTT_PASSWORD=backend_secure_password
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ==================== REDIS (Sesiones y Caché) ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

REDIS_URL=redis://:redis_password_change_in_production@localhost:6379

# ==================== GLITCHTIP ====================
# DSN del proyecto 
GLITCHTIP_DSN=

# ==================== RATE LIMITING ====================
# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ==================== resend email ====================
RESEND_API_KEY=dasdasdas