# ==================== BACKEND NEST.JS ====================
# NODE_ENV controla comportamiento de logs y stack traces en errores
# development: muestra stack traces completos | production: oculta detalles sensibles
NODE_ENV=development
NESTJS_PORT=3000

# CORS Configuration
CORS_ORIGINS=

# JWT Configuration
JWT_REFRESH_SECRET="your-super-secret-jwt-key-change-in-production_refresh"
JWT_ACCESS_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m

# ==================== INFLUXDB (Time Series) ====================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=7sopTQfPFk5myDsFYhMO1BchgqBCjEdaQSMKi8bAwvWO1RDd0tDsWQRpSawDBHKsf1LXa8gypEAd82w-1kGiJQ==
INFLUXDB_ORG=imox_org
INFLUXDB_BUCKET=imox_bucket

# ==================== MARIADB (Relational) ====================
MYSQL_USER=imox_user
MYSQL_PASSWORD=imox_pass
MYSQL_DATABASE=imox_auth
MYSQL_ROOT_PASSWORD=admin123
MYSQL_PORT=3306
# Prisma connection string
MYSQL_URL="mysql://imox_user:imox_pass@localhost:3306/imox_auth"

# ==================== TELEMETRY & SPIKE DETECTION ====================
TELEMETRY_SPIKE_THRESHOLD=0.15
TELEMETRY_VOLTAGE_MAX=140
TELEMETRY_VOLTAGE_MIN=90
TELEMETRY_OFFLINE_TIMEOUT_MIN=10

# ==================== MQTT BROKER ====================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=imox_backend
MQTT_USER=backend_admin
MQTT_PASSWORD=backend_secure_password
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ==================== REDIS (Sesiones y Caché) ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

REDIS_URL=redis://:redis_password_change_in_production@localhost:6379
# En Docker: REDIS_URL=redis://:password@redis:6379

# ==================== GLITCHTIP ====================
GLITCHTIP_PORT=8000
GLITCHTIP_DB_PASSWORD=glitchtip_secure_pass_change_me

# IMPORTANTE: Generar con: openssl rand -hex 50
# Debe tener mínimo 50 caracteres
GLITCHTIP_SECRET_KEY=change-this-to-a-random-secret-key-min-50-chars-use-openssl-rand

GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=noreply@imox.local
GLITCHTIP_EMAIL_URL=consolemail://

# DSN del proyecto 
GLITCHTIP_DSN=

# ==================== BREVO (Email) ====================
BREVO_API_KEY=
EMAIL_SENDER=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10