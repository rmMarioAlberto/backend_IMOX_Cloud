# ==================== BACKEND NEST.JS ====================
NODE_ENV=development
NESTJS_PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ==================== MONGODB ====================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=imox_mongo
MONGO_PORT=27017

# ==================== POSTGRESQL ====================
POSTGRES_USER=imox_user
POSTGRES_PASSWORD=imox_pass
POSTGRES_DB=imox_postgres
POSTGRES_PORT=5432

# ==================== MQTT BROKER ====================
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ==================== REDIS (Sesiones y Caché) ====================
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

# ==================== GLITCHTIP ====================
GLITCHTIP_PORT=8000
GLITCHTIP_DB_PASSWORD=glitchtip_secure_pass_change_me

# IMPORTANTE: Generar con: openssl rand -hex 50
# Debe tener mínimo 50 caracteres
GLITCHTIP_SECRET_KEY=change-this-to-a-random-secret-key-min-50-chars-use-openssl-rand

GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=noreply@imox.local
GLITCHTIP_EMAIL_URL=consolemail://

# GlitchTip DSN (obtener después de crear proyecto en GlitchTip)
# Ir a http://localhost:8000 → Crear proyecto → Copiar DSN
# Formato: https://public-key@your-domain/project-id
GLITCHTIP_DSN=

# ==================== NOTAS ====================
# 1. Copiar este archivo como .env: cp .env.example .env
# 2. NUNCA commitear el archivo .env al repositorio
# 3. Generar GLITCHTIP_SECRET_KEY con: openssl rand -hex 50
# 4. El DSN de GlitchTip se obtiene después de crear un proyecto en http://localhost:8000
# 5. Cambiar TODAS las contraseñas antes de producción