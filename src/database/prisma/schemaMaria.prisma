generator client {
  provider      = "prisma-client-js"
  output        = "../../../generated/prismaMysql"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

model iot {
  id            Int     @id @default(autoincrement())
  mac_address   String  @unique(map: "mac_address_UNIQUE") @db.VarChar(50)
  device_secret String? @db.VarChar(255)
  status        Int     @default(0) // 0=Inactivo, 1=Activo (Controlado por Admin)
  is_online     Boolean @default(false) // true=Conectado, false=Desconectado (Controlado por Sistema)
  user_id       Int?

  // Auditoría
  last_connection DateTime? @default(now()) @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @updatedAt @db.Timestamp(6)

  // Relaciones
  user        users?        @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "fk_iot_user")
  ota_updates ota_updates[]

  @@index([user_id], map: "fk_iot_user_idx")
}

model users {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(50)
  email      String   @unique(map: "email_UNIQUE") @db.VarChar(50)
  password   String   @db.VarChar(255)
  role       Int
  status     Int // 1=Activo, 0=Inactivo
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)
  iot        iot[]
}

model ota_updates {
  id         Int      @id @default(autoincrement())
  job_id     String   @unique(map: "job_id_UNIQUE") @db.VarChar(100)
  version    String   @db.VarChar(50)
  url        String   @db.VarChar(255)
  hash       String?  @db.VarChar(100)
  status     String   @default("PENDING") @db.VarChar(50) // PENDING, IN_PROGRESS, COMPLETED, FAILED
  step       String?  @db.VarChar(100) // DOWNLOADING, INSTALLING, etc.
  device_id  Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  iot iot @relation(fields: [device_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_ota_update_iot")

  @@index([device_id], map: "fk_ota_update_iot_idx")
}
