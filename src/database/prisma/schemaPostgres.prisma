generator client {
  provider     = "prisma-client-js"
  output       = "../../../generated/prismaPostgres"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
} 

model iot {
  id              Int       @id @default(autoincrement())
  mac_address     String    @db.VarChar(50)
  last_connection DateTime? @default(now()) @db.Timestamp(6)
  status          Int
  user_id         Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  users           users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user")
}

model users {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(50)
  email      String    @unique @db.VarChar(50)
  password   String    @db.VarChar(50)
  role       Int
  status     Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  iot        iot[]
}
