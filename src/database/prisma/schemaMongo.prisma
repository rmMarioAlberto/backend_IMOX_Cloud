generator client {
  provider      = "prisma-client-js"
  output        = "../../../generated/prismaMongo"
  binaryTargets = ["native", "linux-musl"]
  moduleFormat  = "cjs"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL_MONGO")
}

model Telemetry {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  iotId  Int    @map("iot_id")
  userId Int    @map("user_id")

  readings Reading[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([iotId, userId])
  @@map("telemetry")
}

type Reading {
  type         String // "normal" | "critical"
  anomaly_type String? // "SPIKE" | "LIMIT"
  electricas   ElectricalData
  diagnostico  DiagnosticData
  timestamp    DateTime       @default(now())
}

type ElectricalData {
  voltaje_v       Float?
  corriente_a     Float?
  potencia_w      Float?
  energia_kwh     Float?
  frecuencia_hz   Float?
  factor_potencia Float?
}

type DiagnosticData {
  ip          String
  rssi_dbm    Int
  pzem_status String
  uptime_s    Int
}
